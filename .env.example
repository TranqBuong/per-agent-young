# Copy this file to .env and fill in your values

# GreenNode AI Platform — required
GREENNODE_AIP_KEY=your-greennode-api-key-here
GREENNODE_AIP_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1

# Optional: override the LLM model (defaults to deepseek/deepseek-v4-flash)
# GREENNODE_MODEL=deepseek/deepseek-v4-flash
# GREENNODE_MODEL_LIGHT=deepseek/deepseek-v4-flash
